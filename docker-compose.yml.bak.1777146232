services:
  web_publica:
    build: .
    container_name: portal_publico
    ports:
      - "8081:80"
    volumes:
      - ./publico:/var/www/html
      - ./compartido/fotos:/var/www/html/fotos
      - ./compartido/videos:/var/www/html/videos
      - ./compartido/musica:/var/www/html/musica
      - ./compartido/data:/var/www/html/data
      - ./publico/mis_ajustes.ini:/usr/local/etc/php/conf.d/mis_ajustes.ini
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost/index.php"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

  web_admin:
    build: .
    container_name: portal_admin
    ports:
      - "8082:80"
    volumes:
      - ./admin:/var/www/html
      - ./compartido/fotos:/var/www/html/fotos
      - ./compartido/videos:/var/www/html/videos
      - ./compartido/musica:/var/www/html/musica
      - ./compartido/data:/var/www/html/data
      - ./admin/mis_ajustes.ini:/usr/local/etc/php/conf.d/mis_ajustes.ini
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost/admin_ritual.php"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
